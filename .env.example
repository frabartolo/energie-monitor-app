# Home Assistant (für E-Auto / optional WP-Entity)
HOMEASSISTANT_BASE_URL=http://homeassistant.local:8123
HOMEASSISTANT_TOKEN=

# Volkszähler-Middleware (Haus-Gesamt, typisch Hauptzähler-kumulativ)
VOLKSZAEHLER_BASE_URL=http://volkszaehler.local:8080
VOLKSZAEHLER_UUID_HAUS=
VOLKSZAEHLER_UUID_PV=

# Optionale Wärmepumpen-REST (nur wenn kein HA-Entity gesetzt)
HEAT_PUMP_API_BASE_URL=

# Home Assistant Entities (kumulative Energie in kWh)
ENTITY_ID_EAUTO_ENERGY=sensor.example_shelly_total_active_energy
ENTITY_ID_WAERMEPUMPE_ENERGY=

REQUEST_TIMEOUT_SECONDS=60
